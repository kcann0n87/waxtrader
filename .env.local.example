# Copy to .env.local and fill in real values for local dev.
# Production values live on Vercel — `vercel env ls` to inspect, or
# `vercel env pull .env.production.local` to mirror prod into a file.

# ============================================================================
# Required for any local run — without these, the app won't boot.
# ============================================================================

# Supabase. Both anon + service role from
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Public site origin. Used by the sitemap, robots.txt, JSON-LD canonical
# URLs, and OG card image refs. Set this to https://waxdepot.io in prod
# (no trailing slash) and to your tunnel URL when testing webhooks locally.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================================
# Stripe — needed for any flow that hits checkout.
# ============================================================================

# Live keys: sk_live_... + pk_live_...
# Test keys:  sk_test_... + pk_test_...
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook signing secret. Get from
# https://dashboard.stripe.com/webhooks → endpoint → Reveal signing secret.
# Must use printf '%s' to set this on Vercel — `echo` appends \n which Stripe
# rejects with an opaque "no signatures matched" error.
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional second webhook secret. The route accepts either, so you can
# rotate without downtime by setting _2 to the new value, swapping the
# Stripe endpoint, then dropping the original.
# STRIPE_WEBHOOK_SECRET_2=whsec_...

# ============================================================================
# Email (Resend). Needed for transactional sends — order confirmation,
# shipped, delivered, dispute, etc. The app no-ops gracefully if unset.
# ============================================================================

RESEND_API_KEY=re_...
RESEND_FROM_ADDRESS="WaxDepot <orders@waxdepot.io>"

# ============================================================================
# Cron secret. Auth header for /api/cron/auto-release. Pick anything — the
# Vercel cron config sends Authorization: Bearer <CRON_SECRET>.
# ============================================================================

CRON_SECRET=any-long-random-string

# ============================================================================
# EasyPost (optional). Powers automatic carrier tracking. Without it,
# /api/easypost/webhook still accepts events but the app can't create
# trackers for new shipments — sellers must update tracking manually.
# ============================================================================

# EASYPOST_API_KEY=EZAK...
# EASYPOST_WEBHOOK_SECRET=any-long-random-string

# ============================================================================
# Observability (optional). All gracefully no-op if the key is unset.
# ============================================================================

# PostHog product analytics. Get from https://posthog.com → project settings.
# Free tier covers 1M events/month.
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry error monitoring. Get DSN from https://sentry.io → project settings.
# Free tier covers 5K errors/month.
# NEXT_PUBLIC_SENTRY_DSN=https://...@...ingest.sentry.io/...

# ============================================================================
# Optional flags.
# ============================================================================

# Set to "1" to render the /coming-soon landing in place of the real site.
# Useful when the public URL is wired up but you're not ready to flip live.
# NEXT_PUBLIC_BETA_MODE=
